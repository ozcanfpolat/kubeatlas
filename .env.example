# ============================================
# KubeAtlas Environment Configuration
# ============================================
# Copy this file to .env and update values:
#   cp .env.example .env
# ============================================

# ============================================
# Application Version
# ============================================
VERSION=latest

# ============================================
# Server Configuration
# ============================================
# Ports exposed on host
API_PORT=8080
UI_PORT=80

# Gin mode: debug, release, test
GIN_MODE=release

# ============================================
# Database Configuration
# ============================================
# For Docker Compose with --profile with-db, use: postgres
# For external database, use your database host
DB_HOST=postgres
DB_PORT=5432
DB_USER=kubeatlas
DB_PASSWORD=CHANGE_ME_secure_password_here
DB_NAME=kubeatlas
DB_SSLMODE=disable

# ============================================
# Security Configuration (REQUIRED)
# ============================================
# Generate secure values:
#   JWT_SECRET: openssl rand -base64 32
#   ENCRYPTION_KEY: openssl rand -hex 32

# JWT token signing secret (min 32 characters)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# Token expiration in hours
JWT_EXPIRATION_HOURS=24

# AES-256 encryption key for sensitive data (64 hex characters)
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ============================================
# LDAP Configuration (Optional)
# ============================================
# Configure via Settings > LDAP in the UI
# Or set these environment variables:
# LDAP_ENABLED=false
# LDAP_SERVER_URL=ldaps://ldap.example.com:636
# LDAP_BIND_DN=cn=service,dc=example,dc=com
# LDAP_BIND_PASSWORD=ldap_password
# LDAP_SEARCH_BASE=ou=users,dc=example,dc=com
# LDAP_SEARCH_FILTER=(uid={username})

# ============================================
# Optional: Redis (for rate limiting)
# ============================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
